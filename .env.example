# Contract Intelligence — environment template
# Copy this file to .env.local and fill in your own values, then:
#   npm run server   (loads .env.local via `node --env-file`)
# .env.local is gitignored — never commit real credentials.
# Full walkthrough of where each value comes from: see SETUP.md.

# ── Service principal (Microsoft Entra app registration) — SERVER-SIDE ONLY ─
# Used by DefaultAzureCredential for non-interactive auth to your Foundry project.
# These are NOT VITE_-prefixed on purpose, so they never reach the browser bundle.
# The app registration needs an "Azure AI User" role on the project (see SETUP.md).
AZURE_TENANT_ID=your-tenant-guid
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-app-registration-client-secret

# ── Azure AI Foundry project + agent ──────────────────────────────────────
# Project endpoint from the Foundry portal (Project → Endpoints & key).
# Format: https://<resource>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# The agent you created in the project, grounded on a knowledge base.
FOUNDRY_AGENT_NAME=your-agent-name
FOUNDRY_AGENT_VERSION=1

# ── Local server (optional) ───────────────────────────────────────────────
# Port the Node API proxy listens on (default 8799). Avoid OS-reserved ports.
# PORT=8799

# ── Frontend (optional) ───────────────────────────────────────────────────
# Where the browser sends /api requests. Leave unset to use the same-origin
# Vite dev proxy (recommended). Only set this if you serve the API elsewhere.
# VITE_API_BASE=
